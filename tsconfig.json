{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./app/*"]
    },
    "types": ["jest", "node"]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "ios",
    "android",
    ".expo",
    "src/ui/Button.tsx",
    "src/ui/Button.stories.tsx",
    "src/ui/BottomNav.tsx",
    "src/ui/BottomNav.stories.tsx",
    "src/ui/Card.tsx",
    "src/ui/Card.stories.tsx",
    "src/ui/Header.tsx",
    "src/ui/Input.tsx",
    "src/ui/Input.stories.tsx",
    "src/ui/Modal.tsx",
    "src/ui/Pill.tsx",
    "src/ui/Pill.stories.tsx",
    "src/ui/Tab.tsx",
    "src/ui/Tab.stories.tsx",
    "src/ui/Text.tsx",
    "src/ui/Text.stories.tsx",
    "src/ui/Toggle.tsx",
    "src/ui/Toggle.stories.tsx",
    "src/ui/ThemeProvider.tsx",
    "src/ui/index.ts",
    "src/ui/tokens-loader.ts",
    ".storybook/**"
  ]
}

