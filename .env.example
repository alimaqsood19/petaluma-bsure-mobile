# bsure-mobile environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# Variables prefixed EXPO_PUBLIC_ are bundled into the JS at build time.

# --- API endpoint ---
# Where the mobile app sends API requests.
# Local dev: http://localhost:3000 (web) or http://<your-machine-ip>:3000 (real device on same wifi).
# Staging / prod: https://api-<env>.bsure.app
EXPO_PUBLIC_API_URL=http://localhost:3000

# --- Local dev stub auth (matches bsure-api ADR 0021) ---
# Anything works as long as the API is in LOCAL_DEV=true mode.
EXPO_PUBLIC_DEV_BEARER=dev-user-1

# --- Auth (Cognito) ---
# Required for non-local builds.
EXPO_PUBLIC_COGNITO_USER_POOL_ID=
EXPO_PUBLIC_COGNITO_REGION=us-east-1
EXPO_PUBLIC_COGNITO_APP_CLIENT_ID=

# --- Sentry ---
# Optional in local dev. Production DSN injected via EAS secrets at build time.
EXPO_PUBLIC_SENTRY_DSN=

# --- Stripe ---
# Mobile only deep-links to web for checkout. No publishable key needed at runtime.
# Web base URL for the deep-link target.
EXPO_PUBLIC_WEB_BASE_URL=https://bsure.app
